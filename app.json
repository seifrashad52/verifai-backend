{
  "expo": {
    "name": "verifAI",
    "slug": "verifai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.verifai.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "package": "com.verifai.app"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow verifAI to access photos for claim screenshots."
        }
      ]
    ]
  }
}
